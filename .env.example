VITE_API_BASE_URL=
VITE_NDMA_ADVISORIES_URL=https://ndma.gov.pk/advisories
VITE_NDMA_SITREPS_URL=https://ndma.gov.pk/sitreps
VITE_NDMA_PROJECTIONS_URL=https://ndma.gov.pk/projection-impact-list_new
VITE_PMD_RSS_URL=https://cap-sources.s3.amazonaws.com/pk-pmd-en/rss.xml
AI_PROVIDER=openai
OPENAI_FALLBACK_TO_HUGGINGFACE=false
# Support for multiple API keys: comma-separated for automatic rotation when quota is hit
OPENAI_API_KEYS=sk-your-openai-api-key-1,sk-your-openai-api-key-2
# Fallback for single key if OPENAI_API_KEYS not provided
OPENAI_API_KEY=sk-your-openai-api-key-here
# Optional dedicated keys for Cost Estimator AI (fallbacks to OPENAI_API_KEYS/OPENAI_API_KEY when omitted)
COST_ESTIMATOR_OPENAI_API_KEYS=
COST_ESTIMATOR_OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
HUGGINGFACE_API_KEY=
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
HUGGINGFACE_CHAT_MODEL=meta-llama/Llama-3.1-8B-Instruct
HUGGINGFACE_VISION_MODEL=meta-llama/Llama-3.2-11B-Vision-Instruct
HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-dev
VISION_API_PORT=8787
COMMUNITY_ISSUES_ADMIN_TOKEN=
